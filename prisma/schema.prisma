generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model DatabaseFoundationFixture {
  id        BigInt   @id @default(autoincrement()) @db.BigInt
  key       String   @unique(map: "database_foundation_fixture_key_key") @db.VarChar(64)
  quantity  Int      @db.Integer
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("_database_foundation_fixture")
  @@schema("app")
}

model User {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username        String              @unique(map: "user_username_key") @db.VarChar(32)
  email           String?             @unique(map: "user_email_key") @db.VarChar(254)
  role            String              @db.VarChar(5)
  status          String              @default("ACTIVE") @db.VarChar(8)
  preferredLocale String?             @map("preferred_locale") @db.VarChar(5)
  checkoutDataPolicy String            @default("NONE") @map("checkout_data_policy") @db.VarChar(22)
  storefrontSlug    String?            @unique(map: "user_storefront_slug_key") @map("storefront_slug") @db.VarChar(63)
  storefrontDisplayNamePtBr String?    @map("storefront_display_name_pt_br") @db.VarChar(160)
  storefrontDisplayNameEn String?      @map("storefront_display_name_en") @db.VarChar(160)
  storefrontAccentColor String?        @map("storefront_accent_color") @db.VarChar(7)
  storefrontEnabled Boolean            @default(false) @map("storefront_enabled")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  credential       PasswordCredential?
  nauttCredential  NauttCredential?
  providerQuotes   ProviderQuote[]
  providerOrders   ProviderOrder[]
  products         Product[]
  productCategories ProductCategory[]
  paymentLinks     PaymentLink[]
  paymentLinkOrders PaymentLinkOrder[]
  checkoutAttempts CheckoutAttempt[]
  webhookDeliveries WebhookDelivery[]
  mediaObjects       MediaObject[]
  sessions          Session[]

  @@map("user")
  @@schema("app")
}

model MediaObject {
  id                String    @id @db.Uuid
  identifier        String    @unique(map: "media_object_identifier_key") @db.VarChar(43)
  storageKey        String    @unique(map: "media_object_storage_key_key") @map("storage_key") @db.VarChar(43)
  ownerId           String    @map("owner_id") @db.Uuid
  purpose           String    @db.VarChar(15)
  state             String    @db.VarChar(9)
  lifecycleRevision BigInt    @map("lifecycle_revision") @db.BigInt
  mimeType          String    @map("mime_type") @db.VarChar(10)
  byteSize          BigInt    @map("byte_size") @db.BigInt
  width             Int       @db.Integer
  height            Int       @db.Integer
  sha256            String    @db.VarChar(64)
  purgeAfter        DateTime? @map("purge_after") @db.Timestamptz(3)
  createdAt         DateTime  @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime  @map("updated_at") @db.Timestamptz(3)
  owner             User      @relation(fields: [ownerId], references: [id], onDelete: Restrict)

  @@index([ownerId, purpose, state], map: "media_object_owner_purpose_state_idx")
  @@index([state, purgeAfter], map: "media_object_state_purge_after_idx")
  @@map("media_object")
  @@schema("app")
}

model Session {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  tokenDigest       String   @unique(map: "session_token_digest_key") @map("token_digest") @db.VarChar(64)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  lastSeenAt        DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  absoluteExpiresAt DateTime @map("absolute_expires_at") @db.Timestamptz(3)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt, id], map: "session_user_created_at_id_idx")
  @@map("session")
  @@schema("app")
}

model PasswordCredential {
  userId       String   @id @map("user_id") @db.Uuid
  passwordHash String   @map("password_hash") @db.VarChar(128)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credential")
  @@schema("app")
}

model NauttCredential {
  userId                   String    @id @map("user_id") @db.Uuid
  encryptedApiKey          String    @map("encrypted_api_key") @db.Text
  credentialRevision       String    @unique(map: "nautt_credential_credential_revision_key") @default(dbgenerated("gen_random_uuid()")) @map("credential_revision") @db.Uuid
  webhookRegistrationState String    @default("UNREGISTERED") @map("webhook_registration_state") @db.VarChar(13)
  providerWebhookId        String?   @map("provider_webhook_id") @db.Uuid
  encryptedWebhookSecret  String?   @map("encrypted_webhook_secret") @db.Text
  webhookRegisteredAt     DateTime? @map("webhook_registered_at") @db.Timestamptz(3)
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nautt_credential")
  @@schema("app")
}

model DeploymentBootstrap {
  id                 Int      @id @db.SmallInt
  initialAdminUserId String   @map("initial_admin_user_id") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("deployment_bootstrap")
  @@schema("app")
}

model GlobalPaymentSettings {
  id             Int      @id @db.SmallInt
  currencies     String[] @db.Text
  paymentMethods String[] @map("payment_methods") @db.Text
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("global_payment_settings")
  @@schema("app")
}

model CatalogCurrencyPair {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label                String   @db.VarChar(128)
  currencyUuid         String   @map("currency_uuid") @db.Uuid
  exchangeCurrencyUuid String   @map("exchange_currency_uuid") @db.Uuid
  active               Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  paymentLinks         PaymentLink[]

  @@unique([currencyUuid, exchangeCurrencyUuid], map: "catalog_currency_pair_uuids_key")
  @@map("catalog_currency_pair")
  @@schema("app")
}

model CatalogPaymentMethod {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label             String   @db.VarChar(128)
  paymentMethodUuid String   @map("payment_method_uuid") @db.Uuid
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([paymentMethodUuid], map: "catalog_payment_method_uuid_key")
  @@map("catalog_payment_method")
  @@schema("app")
}

model Product {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId         String   @map("owner_id") @db.Uuid
  categoryId      String?  @map("category_id") @db.Uuid
  internalName    String   @map("internal_name") @db.VarChar(128)
  titlePtBr       String   @map("title_pt_br") @db.VarChar(160)
  titleEn         String   @map("title_en") @db.VarChar(160)
  descriptionPtBr String   @map("description_pt_br") @db.VarChar(2000)
  descriptionEn   String   @map("description_en") @db.VarChar(2000)
  price           String   @db.Text
  active          Boolean  @default(true)
  version         Int      @default(0) @db.Integer
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  category        ProductCategory? @relation(fields: [categoryId, ownerId], references: [id, ownerId], onDelete: Restrict)
  paymentLinks    PaymentLink[]
  paymentLinkOrders PaymentLinkOrder[]

  @@unique([id, ownerId], map: "product_id_owner_id_key")
  @@index([ownerId, internalName, id], map: "product_owner_internal_name_id_idx")
  @@index([ownerId, categoryId, id], map: "product_owner_category_id_idx")
  @@map("product")
  @@schema("app")
}

model ProductCategory {
  id        String    @id @db.Uuid
  ownerId   String    @map("owner_id") @db.Uuid
  namePtBr  String    @map("name_pt_br") @db.VarChar(160)
  nameEn    String    @map("name_en") @db.VarChar(160)
  active    Boolean
  version   Int       @db.Integer
  createdAt DateTime  @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime  @map("updated_at") @db.Timestamptz(3)
  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  products  Product[]

  @@unique([id, ownerId], map: "product_category_id_owner_id_key")
  @@unique([ownerId, namePtBr], map: "product_category_owner_name_pt_br_key")
  @@unique([ownerId, nameEn], map: "product_category_owner_name_en_key")
  @@index([ownerId, active, namePtBr, id], map: "product_category_owner_active_name_idx")
  @@map("product_category")
  @@schema("app")
}

model PaymentLink {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier     String              @unique(map: "payment_link_identifier_key") @db.VarChar(24)
  ownerId        String              @map("owner_id") @db.Uuid
  productId      String              @map("product_id") @db.Uuid
  currencyPairId String              @map("currency_pair_id") @db.Uuid
  linkType       String              @map("link_type") @db.VarChar(10)
  expiresAt      DateTime?           @map("expires_at") @db.Timestamptz(3)
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  owner          User                @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  product        Product             @relation(fields: [productId, ownerId], references: [id, ownerId], onDelete: Restrict)
  currencyPair   CatalogCurrencyPair @relation(fields: [currencyPairId], references: [id], onDelete: Restrict)
  paymentLinkOrders PaymentLinkOrder[]
  checkoutAttempts CheckoutAttempt[]
  singleUseSettlement PaymentLinkSingleUseSettlement?

  @@unique([id, ownerId], map: "payment_link_id_owner_id_key")
  @@unique([id, ownerId, productId], map: "payment_link_id_owner_product_id_key")
  @@index([createdAt, id], map: "payment_link_created_at_id_idx")
  @@index([ownerId, createdAt, id], map: "payment_link_owner_created_at_id_idx")
  @@index([productId], map: "payment_link_product_id_idx")
  @@index([currencyPairId], map: "payment_link_currency_pair_id_idx")
  @@map("payment_link")
  @@schema("app")
}

model ProviderQuote {
  quoteUuid String          @id @map("quote_uuid") @db.Uuid
  ownerId   String          @map("owner_id") @db.Uuid
  expiresAt DateTime        @map("expires_at") @db.Timestamptz(3)
  claimedAt DateTime?       @map("claimed_at") @db.Timestamptz(3)
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  owner     User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  order     ProviderOrder?

  @@unique([quoteUuid, ownerId], map: "provider_quote_quote_uuid_owner_id_key")
  @@index([ownerId, expiresAt], map: "provider_quote_owner_expires_at_idx")
  @@map("provider_quote")
  @@schema("app")
}

model ProviderOrder {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId               String    @map("owner_id") @db.Uuid
  quoteUuid             String    @unique(map: "provider_order_quote_uuid_key") @map("quote_uuid") @db.Uuid
  providerOrderUuid     String?   @unique(map: "provider_order_provider_order_uuid_key") @map("provider_order_uuid") @db.Uuid
  creationState         String    @default("CREATING") @map("creation_state") @db.VarChar(13)
  status                String?   @db.VarChar(10)
  fiatAmount            String?   @map("fiat_amount") @db.Text
  cryptoAmount          String?   @map("crypto_amount") @db.Text
  nauttQuote             String?   @map("nautt_quote") @db.Text
  providerExpiresAt     DateTime? @map("provider_expires_at") @db.Timestamptz(3)
  paymentMethod         String?   @map("payment_method") @db.Text
  pixCopyPaste          String?   @map("pix_copy_paste") @db.Text
  pixQrcodeUrl          String?   @map("pix_qrcode_url") @db.Text
  paymentLinkOrderId    String?   @unique(map: "provider_order_payment_link_order_id_key") @map("payment_link_order_id") @db.Uuid
  reconciliationVersion Int       @default(0) @map("reconciliation_version") @db.Integer
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner                 User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  quote                 ProviderQuote @relation(fields: [quoteUuid, ownerId], references: [quoteUuid, ownerId], onDelete: Cascade)
  webhookDeliveries     WebhookDelivery[]
  webhookRecoveryLease  WebhookRecoveryLease?
  paymentLinkOrder      PaymentLinkOrder? @relation("PaymentLinkOrderProviderOrder", fields: [paymentLinkOrderId, ownerId], references: [id, ownerId], onDelete: Restrict)

  @@index([ownerId, status], map: "provider_order_owner_status_idx")
  @@unique([id, ownerId], map: "provider_order_id_owner_id_key")
  @@unique([quoteUuid, ownerId], map: "provider_order_quote_uuid_owner_id_key")
  @@unique([paymentLinkOrderId, ownerId], map: "provider_order_payment_link_order_owner_key")
  @@map("provider_order")
  @@schema("app")
}

model PaymentLinkOrder {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId               String   @map("owner_id") @db.Uuid
  paymentLinkId         String   @map("payment_link_id") @db.Uuid
  productId             String   @map("product_id") @db.Uuid
  productPrice          String   @map("product_price") @db.Text
  currencyUuid          String   @map("currency_uuid") @db.Uuid
  exchangeCurrencyUuid  String   @map("exchange_currency_uuid") @db.Uuid
  checkoutDataPolicy    String   @map("checkout_data_policy") @db.VarChar(22)
  name                  String?  @db.VarChar(160)
  email                 String?  @db.VarChar(254)
  cpf                   String?  @db.Char(11)
  street                String?  @db.VarChar(160)
  number                String?  @db.VarChar(32)
  district              String?  @db.VarChar(120)
  city                  String?  @db.VarChar(120)
  stateUf               String?  @map("state_uf") @db.Char(2)
  postalCode            String?  @map("postal_code") @db.Char(8)
  country               String?  @db.Char(2)
  complement            String?  @db.VarChar(160)
  state                 String   @default("CREATED") @db.VarChar(13)
  lifecycleVersion      Int      @default(0) @map("lifecycle_version") @db.Integer
  settledAt             DateTime? @map("settled_at") @db.Timestamptz(3)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner                 User     @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  paymentLink           PaymentLink @relation(fields: [paymentLinkId, ownerId, productId], references: [id, ownerId, productId], onDelete: Restrict)
  product               Product  @relation(fields: [productId, ownerId], references: [id, ownerId], onDelete: Restrict)
  providerOrder         ProviderOrder? @relation("PaymentLinkOrderProviderOrder")
  singleUseSettlement   PaymentLinkSingleUseSettlement?
  checkoutAttempt       CheckoutAttempt?

  @@unique([id, ownerId], map: "payment_link_order_id_owner_id_key")
  @@map("payment_link_order")
  @@schema("app")
}

model CheckoutAttempt {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId               String   @map("owner_id") @db.Uuid
  paymentLinkId         String   @map("payment_link_id") @db.Uuid
  paymentLinkOrderId    String   @unique(map: "checkout_attempt_payment_link_order_id_key") @map("payment_link_order_id") @db.Uuid
  retryKeyVerifier      String   @map("retry_key_verifier") @db.Char(64)
  requestVerifier       String   @map("request_verifier") @db.Char(64)
  capabilityNonce       String   @map("capability_nonce") @db.Char(43)
  capabilityKeyVersion  String   @map("capability_key_version") @db.VarChar(16)
  capabilityVerifier    String   @map("capability_verifier") @db.Char(64)
  capabilityExpiresAt   DateTime @map("capability_expires_at") @db.Timestamptz(3)
  capabilityRevokedAt   DateTime? @map("capability_revoked_at") @db.Timestamptz(3)
  state                 String   @default("RESERVED") @db.VarChar(13)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner                 User     @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  paymentLink           PaymentLink @relation(fields: [paymentLinkId, ownerId], references: [id, ownerId], onDelete: Restrict)
  paymentLinkOrder      PaymentLinkOrder @relation(fields: [paymentLinkOrderId, ownerId], references: [id, ownerId], onDelete: Restrict)

  @@unique([paymentLinkId, retryKeyVerifier], map: "checkout_attempt_link_retry_key_verifier_key")
  @@unique([paymentLinkOrderId, ownerId], map: "checkout_attempt_order_owner_key")
  @@index([ownerId, capabilityExpiresAt], map: "checkout_attempt_owner_capability_expiry_idx")
  @@map("checkout_attempt")
  @@schema("app")
}

model PaymentLinkSingleUseSettlement {
  paymentLinkId      String           @id @map("payment_link_id") @db.Uuid
  ownerId            String           @map("owner_id") @db.Uuid
  paymentLinkOrderId String           @unique(map: "payment_link_single_use_settlement_order_key") @map("payment_link_order_id") @db.Uuid
  claimedAt          DateTime         @default(now()) @map("claimed_at") @db.Timestamptz(3)
  paymentLink        PaymentLink      @relation(fields: [paymentLinkId, ownerId], references: [id, ownerId], onDelete: Restrict)
  paymentLinkOrder   PaymentLinkOrder @relation(fields: [paymentLinkOrderId, ownerId], references: [id, ownerId], onDelete: Restrict)

  @@unique([paymentLinkId, ownerId], map: "payment_link_single_use_settlement_link_owner_key")
  @@unique([paymentLinkOrderId, ownerId], map: "payment_link_single_use_settlement_order_owner_key")
  @@map("payment_link_single_use_settlement")
  @@schema("app")
}

model WebhookDelivery {
  deliveryUuid          String                   @id @map("delivery_uuid") @db.Uuid
  ownerId               String                   @map("owner_id") @db.Uuid
  providerOrderId       String?                  @map("provider_order_id") @db.Uuid
  providerOrderUuid     String                   @map("provider_order_uuid") @db.Uuid
  eventType             String                   @map("event_type") @db.VarChar(32)
  providerCreatedAt     DateTime                 @map("provider_created_at") @db.Timestamptz(3)
  providerAttemptNumber Int?                     @map("provider_attempt_number") @db.Integer
  evidenceSource        String                   @default("INTAKE") @map("evidence_source") @db.VarChar(8)
  providerWebhookUuid   String?                  @map("provider_webhook_uuid") @db.Uuid
  providerIsDelivered   Boolean?                 @map("provider_is_delivered")
  providerIsPermanentlyFailed Boolean?           @map("provider_is_permanently_failed")
  payloadDigest         String?                  @map("payload_digest") @db.Char(64)
  decision              String                   @default("RETRYABLE") @db.VarChar(10)
  leaseExpiresAt        DateTime?                @map("lease_expires_at") @db.Timestamptz(3)
  processingAttemptNumber Int?                   @map("processing_attempt_number") @db.Integer
  createdAt             DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner                 User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  providerOrder         ProviderOrder?           @relation(fields: [providerOrderId, ownerId], references: [id, ownerId], onDelete: Cascade)
  attempts              WebhookDeliveryAttempt[]

  @@index([ownerId, providerOrderUuid], map: "webhook_delivery_owner_provider_order_idx")
  @@index([decision, leaseExpiresAt], map: "webhook_delivery_decision_lease_idx")
  @@map("webhook_delivery")
  @@schema("app")
}

model WebhookDeliveryAttempt {
  id                    BigInt          @id @default(autoincrement()) @db.BigInt
  deliveryUuid          String          @map("delivery_uuid") @db.Uuid
  attemptNumber         Int             @map("attempt_number") @db.Integer
  outcome               String          @db.VarChar(10)
  providerAttemptNumber Int?            @map("provider_attempt_number") @db.Integer
  evidenceSource        String          @default("INTAKE") @map("evidence_source") @db.VarChar(8)
  providerWebhookUuid   String?         @map("provider_webhook_uuid") @db.Uuid
  providerIsDelivered   Boolean?        @map("provider_is_delivered")
  providerIsPermanentlyFailed Boolean?  @map("provider_is_permanently_failed")
  payloadDigest         String?         @map("payload_digest") @db.Char(64)
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  completedAt           DateTime?       @map("completed_at") @db.Timestamptz(3)
  delivery              WebhookDelivery @relation(fields: [deliveryUuid], references: [deliveryUuid], onDelete: Cascade)

  @@unique([deliveryUuid, attemptNumber], map: "webhook_delivery_attempt_delivery_number_key")
  @@index([deliveryUuid, createdAt], map: "webhook_delivery_attempt_delivery_created_idx")
  @@map("webhook_delivery_attempt")
  @@schema("app")
}

model WebhookRecoveryLease {
  providerOrderId String        @id @map("provider_order_id") @db.Uuid
  ownerId         String        @map("owner_id") @db.Uuid
  fenceToken      String        @map("fence_token") @db.Uuid
  leaseExpiresAt  DateTime      @map("lease_expires_at") @db.Timestamptz(3)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  providerOrder   ProviderOrder @relation(fields: [providerOrderId, ownerId], references: [id, ownerId], onDelete: Cascade)

  @@unique([providerOrderId, ownerId], map: "webhook_recovery_lease_order_owner_key")
  @@index([leaseExpiresAt], map: "webhook_recovery_lease_expiry_idx")
  @@map("webhook_recovery_lease")
  @@schema("app")
}
