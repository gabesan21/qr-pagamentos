{
  "name": "qr-pagamentos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "26.4.0",
    "pnpm": "11.3.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "prisma generate",
    "db:test": "node pop/scripts/db-test.mjs",
    "db:migration-policy": "node pop/scripts/migration-policy.mjs verify && node pop/scripts/migration-policy-contract.mjs",
    "db:contract-check": "pnpm db:migration-policy && node pop/scripts/db-contract-check.mjs",
    "container:prepare-secrets": "node pop/scripts/container-prepare-secrets.mjs",
    "container:contract-check": "node pop/scripts/container-contract-check.mjs",
    "container:test": "node pop/scripts/container-test.mjs",
    "tokens:generate": "node scripts/generate-design-tokens.mjs",
    "tokens:check": "node scripts/generate-design-tokens.mjs --check",
    "brand:generate": "node scripts/generate-brand-assets.mjs",
    "brand:check": "node scripts/generate-brand-assets.mjs --check",
    "lint": "pnpm tokens:check && pnpm brand:check && node scripts/check-design-tokens.mjs && eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "design-system:evidence": "pnpm build && playwright test design-system.evidence.spec.ts --project=chromium --workers=1",
    "design-system:evidence:verify": "node scripts/verify-design-system-evidence.mjs",
    "login:evidence": "pnpm build && playwright test login.evidence.spec.ts --project=chromium --workers=1",
    "login:evidence:verify": "node scripts/verify-login-evidence.mjs",
    "admin:source-check": "node scripts/check-admin-ui-inventory.mjs",
    "admin:contract-check": "node scripts/check-admin-contract-sync.mjs",
    "admin:evidence": "node scripts/run-admin-evidence.mjs",
    "admin:evidence:verify": "node scripts/verify-admin-evidence.mjs",
    "epoch1:source-check": "node scripts/check-epoch1-source.mjs",
    "precheck": "pnpm db:generate",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "5.2.8",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "shadcn": "4.13.0",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
