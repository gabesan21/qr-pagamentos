# Loopback port published by the application.
APP_PORT=3000

# Absolute paths to distinct password files. Each file must be owned by the
# invoking operator and have mode 0600. Never put a password value in this file.
POSTGRES_ADMIN_PASSWORD_FILE=/absolute/path/to/postgres-admin-password
MIGRATOR_PASSWORD_FILE=/absolute/path/to/qr-migrator-password
RUNTIME_PASSWORD_FILE=/absolute/path/to/qr-runtime-password
