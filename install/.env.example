# Loopback port published by the application.
APP_PORT=3000

# Required login identifier and optional contact email for the deployment-seeded administrator.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=

# Required 32-byte base64url encryption key for per-user Nautt API keys.
# Generate with: node -e "process.stdout.write(crypto.randomBytes(32).toString('base64url'))"
# Back this key up outside the host; losing it makes all stored Nautt keys irrecoverable.
NAUTT_ENCRYPTION_KEY=

# Required canonical HTTPS callback registered for every owner webhook.
NAUTT_WEBHOOK_CALLBACK_URL=https://payments.example.com/api/nautt/webhooks

# Optional Nautt API base URL override (canonical absolute HTTPS, no credentials or fragment).
# Leave unset to use the production default https://api.nauttfinance.com/api/v2.
# NAUTT_API_BASE_URL=https://api-stage.nauttfinance.com/api/v2

# Use three distinct passwords. This file is a template; copy it to install/.env,
# which is ignored by Git, and replace every placeholder before installation.
POSTGRES_ADMIN_PASSWORD=replace-with-a-strong-admin-password
MIGRATOR_PASSWORD=replace-with-a-distinct-migrator-password
RUNTIME_PASSWORD=replace-with-a-distinct-runtime-password
